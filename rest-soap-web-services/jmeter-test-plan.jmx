<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.5">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Plan de Pruebas - Servicios Web" enabled="true">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <stringProp name="TestPlan.user_define_classpath"></stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.comment" elementType="TestPlanSection" guiclass="TestPlanSectionGui" testclass="TestPlanSection" testname="Test Plan" enabled="true"/>
      <stringProp name="TestPlan.comment">
Plan de pruebas de carga y escalabilidad para:
- APIs REST de catálogos
- Servicio SOAP de divisas
- Autenticación OAuth2
- Auditoría y caché
      </stringProp>
    </TestPlan>
    <hashTree>
      <!-- Thread Group para pruebas de API REST -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Grupo 1: Pruebas REST API (50 threads)" enabled="true">
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller" enabled="true">
          <boolProp name="LoopController.continue_forever">false</boolProp>
          <stringProp name="LoopController.loops">10</stringProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">50</stringProp>
        <stringProp name="ThreadGroup.ramp_time">10</stringProp>
        <longProp name="ThreadGroup.start_time">1425600000000</longProp>
        <longProp name="ThreadGroup.end_time">1425600000000</longProp>
        <boolProp name="ThreadGroup.scheduler">false</boolProp>
        <stringProp name="ThreadGroup.duration"></stringProp>
        <stringProp name="ThreadGroup.delay"></stringProp>
      </ThreadGroup>
      <hashTree>
        <!-- HTTP Request: Obtener categorías -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/catalogos/categorias" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
            <collectionProp name="Arguments.arguments">
              <HTTPArgument name="page" value="0" enabled="true"/>
              <HTTPArgument name="size" value="10" enabled="true"/>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">localhost</stringProp>
          <stringProp name="HTTPSampler.port">8080</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <stringProp name="HTTPSampler.path">/api/catalogos/categorias</stringProp>
          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- HTTP Request: Obtener productos -->
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /api/catalogos/productos" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
            <collectionProp name="Arguments.arguments">
              <HTTPArgument name="page" value="0" enabled="true"/>
              <HTTPArgument name="size" value="10" enabled="true"/>
            </collectionProp>
          </elementProp>
          <stringProp name="HTTPSampler.domain">localhost</stringProp>
          <stringProp name="HTTPSampler.port">8080</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
          <stringProp name="HTTPSampler.path">/api/catalogos/productos</stringProp>
          <stringProp name="HTTPSampler.contentEncoding"></stringProp>
          <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
          <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
          <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
          <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
        </HTTPSamplerProxy>
        <hashTree/>

        <!-- Assertion: Verificar respuesta 200 -->
        <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assertion" enabled="true">
          <elementProp name="TestElements.test_elements" elementType="CollectionProperty" guiclass="CollectionProperty" testclass="CollectionProperty">
            <elementProp name="" elementType="ResponseAssertion" guiclass="TestFragmentController" testclass="ResponseAssertion" testname="" enabled="true">
              <intProp name="Assertion.test_type">1</intProp>
              <stringProp name="Assertion.test_strings">200</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_field">Assertion.response_code</intProp>
            </elementProp>
          </elementProp>
          <stringProp name="TestPlan.comments">Verificar que la respuesta sea 200 OK</stringProp>
        </ResponseAssertion>
        <hashTree/>
      </hashTree>

      <!-- Listener: Resultados en tabla -->
      <ResultCollector guiclass="TableVisualizer" testclass="ResultCollector" testname="Ver Resultados en Tabla" enabled="true">
        <elementProp name="sample_save_config" elementType="SampleSaveConfiguration">
          <stringProp name="sample_save_config">xml</stringProp>
          <stringProp name="sample_save_config">samplerData</stringProp>
          <stringProp name="sample_save_config">responseData</stringProp>
          <stringProp name="sample_save_config">responseHeaders</stringProp>
          <stringProp name="sample_save_config">responseFile</stringProp>
          <stringProp name="sample_save_config">responseCode</stringProp>
          <stringProp name="sample_save_config">responseMessage</stringProp>
          <stringProp name="sample_save_config">isSampler</stringProp>
          <stringProp name="sample_save_config">samplerLabel</stringProp>
          <stringProp name="sample_save_config">elapsedTime</stringProp>
          <stringProp name="sample_save_config">allThreads</stringProp>
          <stringProp name="sample_save_config">bytes</stringProp>
          <stringProp name="sample_save_config">sentBytes</stringProp>
          <stringProp name="sample_save_config">url</stringProp>
          <stringProp name="sample_save_config">filename</stringProp>
          <stringProp name="sample_save_config">hostname</stringProp>
          <stringProp name="sample_save_config">connect</stringProp>
          <stringProp name="sample_save_config">encoding</stringProp>
          <stringProp name="sample_save_config">idleTime</stringProp>
          <stringProp name="sample_save_config">success</stringProp>
          <stringProp name="sample_save_config">threadName</stringProp>
          <stringProp name="sample_save_config">dataType</stringProp>
          <stringProp name="sample_save_config">assertions</stringProp>
          <stringProp name="sample_save_config">subresults</stringProp>
          <stringProp name="sample_save_config">timestamp</stringProp>
        </elementProp>
        <stringProp name="filename">jmeter-results.jtl</stringProp>
      </ResultCollector>
      <hashTree/>

      <!-- Listener: Gráfico de estadísticas -->
      <ResultCollector guiclass="StatGraphVisualizer" testclass="ResultCollector" testname="Gráfico de Estadísticas" enabled="true">
        <elementProp name="sample_save_config" elementType="SampleSaveConfiguration">
          <stringProp name="sample_save_config">xml</stringProp>
        </elementProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>

      <!-- Listener: Resumen -->
      <ResultCollector guiclass="SummaryReport" testclass="ResultCollector" testname="Reporte de Resumen" enabled="true">
        <elementProp name="sample_save_config" elementType="SampleSaveConfiguration">
          <stringProp name="sample_save_config">xml</stringProp>
        </elementProp>
        <stringProp name="filename"></stringProp>
      </ResultCollector>
      <hashTree/>
    </hashTree>
  </hashTree>
</jmeterTestPlan>

