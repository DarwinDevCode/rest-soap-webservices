    {
      "name": "4. SOAP - Divisas",
      "item": [
        {
          "name": "4.1 POST - Convertir USD a EUR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\" \n               xmlns:tns=\"http://www.uteq.org/soap/divisas\">\n  <soap:Body>\n    <tns:ConversionRequest>\n      <tns:monto>100</tns:monto>\n      <tns:divisaOrigen>USD</tns:divisaOrigen>\n      <tns:divisaDestino>EUR</tns:divisaDestino>\n    </tns:ConversionRequest>\n  </soap:Body>\n</soap:Envelope>"
            },
            "url": {
              "raw": "{{base_url}}/ws",
              "host": ["{{base_url}}"],
              "path": ["ws"]
            }
          }
        },
        {
          "name": "4.2 POST - Convertir USD a MXN",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "text/xml"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<?xml version=\"1.0\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\" \n               xmlns:tns=\"http://www.uteq.org/soap/divisas\">\n  <soap:Body>\n    <tns:ConversionRequest>\n      <tns:monto>1000</tns:monto>\n      <tns:divisaOrigen>USD</tns:divisaOrigen>\n      <tns:divisaDestino>MXN</tns:divisaDestino>\n    </tns:ConversionRequest>\n  </soap:Body>\n</soap:Envelope>"
            },
            "url": {
              "raw": "{{base_url}}/ws",
              "host": ["{{base_url}}"],
              "path": ["ws"]
            }
          }
        },
        {
          "name": "4.3 GET - Ver WSDL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/ws/divisas.wsdl",
              "host": ["{{base_url}}"],
              "path": ["ws", "divisas.wsdl"]
            }
          }
        }
