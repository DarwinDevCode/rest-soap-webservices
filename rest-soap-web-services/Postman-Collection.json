  "item": [
    {
      "name": "1. Catálogos REST",
      "item": [
        {
          "name": "1.1 GET - Obtener todas las categorías",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/catalogos/categorias?page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "catalogos", "categorias"],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "1.2 POST - Crear categoría",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"nombre\": \"Electrónica\", \"descripcion\": \"Productos electrónicos\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/catalogos/categorias",
              "host": ["{{base_url}}"],
              "path": ["api", "catalogos", "categorias"]
            }
          }
        },
